# Public client config — all VITE_* vars are inlined into the browser bundle
# at build time. NEVER put server secrets here (no service-role keys, no
# provider API keys). Only anon/public values belong in the frontend.

# Supabase project URL + anon (public) key. Required.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Backend API origin. Optional — defaults to the deployed Render backend.
VITE_API_URL="https://resume-craft-backend-1r57.onrender.com"

# Razorpay publishable key id (public). Required for checkout.
VITE_RAZORPAY_KEY_ID="rzp_live_or_test_xxx"
